DATABASE_URL=sqlite:///./app.db
UPLOAD_DIR=uploads
# how to calculate this?
MAX_FILE_SIZE=2097152
QDRANT_PATH=./qdrant_data
# For a shared deployment, point at a remote Qdrant instead of the on-disk store:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Auth & scope (shared service) ---
# "passthrough" (structural only) or "namespace" (enforce allowed services/collections).
SCOPE_POLICY_MODE=passthrough
# JSON file of API keys -> scope grants (see config/api_keys.example.json).
# API_KEYS_FILE=./config/api_keys.json
# Or inline JSON: LOCAL_RAG_API_KEYS={"keys":[...]}
# Optional seed profiles (see config/profiles.example.json).
# PROFILES_FILE=./config/profiles.json
# Key the MCP server process authenticates with:
# LOCAL_RAG_API_KEY=replace-with-a-real-key

# --- Observability ---
METRICS_ENABLED=true

GENERATION_BASE_URL=http://127.0.0.1:8080/v1
GENERATION_ENDPOINT=/chat/completions
GENERATION_TIMEOUT=600
GENERATION_TEMPERATURE=0.2
GENERATION_MAX_OUTPUT_TOKENS=300
GENERATION_MAX_CONTEXT_CHARS=6000
GENERATION_MAX_CHARS_PER_CHUNK=1800

DENSE_RETRIEVAL_LIMIT=15
LEXICAL_RETRIEVAL_LIMIT=15
FUSION_RRF_K=60
